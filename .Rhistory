dplyr::rename(value_base = value) %>%
dplyr::select(-scenario),
by = c("region", "coicop", "year")
) %>%
# filter out negative prices from delivered biomass
dplyr::filter(coicop != deliv_bio_coicop) %>%
dplyr::mutate(price_diff = value / value_base)
